# Local defaults. All model backends are optional; mock works without keys.
PRIVACY_VLM_RESIZE_WIDTH=640
PRIVACY_VLM_DEFAULT_NUM_FRAMES=8
PRIVACY_VLM_OUTPUTS_DIR=outputs/runs

# Optional Ollama VLM backend.
# Research default:
# - gemma3:4b is the minimum recommended local VLM for reproducible PoC runs.
# - Use gemma3:12b when the machine has enough memory and latency is acceptable.
OLLAMA_ENABLED=false
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma3:4b

# Optional OpenAI-compatible VLM backend.
OPENAI_COMPATIBLE_ENABLED=false
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=
